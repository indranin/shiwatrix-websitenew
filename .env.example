# Copy this file to .env for local testing, and set the same values as
# environment variables in your hosting provider's dashboard for production.
# Never commit a real .env file — it is already covered by .gitignore.

# SMTP transport used to send contact form emails. Works with Gmail
# (use an App Password, not your login password), Outlook/Microsoft 365,
# SendGrid, Mailgun, Amazon SES, or any other SMTP provider.
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Mailbox that should receive contact form submissions.
CONTACT_TO_EMAIL=hello@shiwatrixlifesciences.com

# Optional: "from" address used when sending. Defaults to SMTP_USER if unset.
# Should generally be on the same domain as SMTP_HOST to avoid spam filtering.
CONTACT_FROM_EMAIL=website@shiwatrixlifesciences.com

# Restrict CORS to your production domain once deployed (e.g.
# https://www.shiwatrixlifesciences.com). Leave unset only for local testing.
ALLOWED_ORIGIN=https://www.shiwatrixlifesciences.com
